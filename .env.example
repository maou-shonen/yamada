# ──────────────────────────────────────────────
# yamada (山田) — 環境變數設定
# ──────────────────────────────────────────────
# 複製此檔案為 .env 並填入實際值：cp .env.example .env
# Discord 和 LINE 為可選平台，至少需設定一個。同一平台的欄位必須成對出現。

# ── 秘密憑證 ──

# Discord Bot（成對設定）
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# LINE Messaging API（成對設定）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ── Per-provider AI 憑證（各 provider 獨立設定，只需設定你使用的 provider） ──

# OpenAI（若未設 OPENAI_API_KEY，SDK 自動讀取 env var）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Anthropic（若未設 ANTHROPIC_API_KEY，SDK 自動讀取 env var）
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=

# Google AI Studio（若未設 GOOGLE_API_KEY，SDK 自動讀取 GOOGLE_GENERATIVE_AI_API_KEY）
# GOOGLE_API_KEY=
# GOOGLE_BASE_URL=

# OpenRouter（預設 https://openrouter.ai/api/v1）
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=

# OpenCode（無內建 preset，需設定 BASE_URL）
# OPENCODE_API_KEY=
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1
# 若 provider 有自訂 BASE_URL 且非 openai-compatible，需指定 compatible mode：
# OPENCODE_COMPATIBLE=openai|anthropic|gemini  （預設 openai-compatible）


# Cloudflare Tunnel（Docker Compose 用，提供公網 HTTPS 給 LINE Webhook）
# TUNNEL_TOKEN=

# ── 人格與基本設定 ──

# SOUL=                          # Bot 人格 system prompt（預設：內建人格）
# DB_PATH=./data/yamada.db       # 單一 SQLite 資料庫檔案路徑
# DISCORD_GROUP_ID_MODE=guild    # guild = 同 server 共用 / channel = 每頻道獨立
# LINE_WEBHOOK_PORT=3000         # LINE Webhook 監聽埠

# ── AI 模型（格式：provider/model-name，逗號分隔 = fallback） ──
# 支援的 provider: openai, anthropic, google, openrouter, opencode

# CHAT_MODEL=openrouter/x-ai/grok-4.1-fast,openrouter/deepseek/deepseek-v3.2  # 聊天模型
# OBSERVER_MODEL=openrouter/x-ai/grok-4.1-fast,openrouter/deepseek/deepseek-v3.2  # Observer 摘要壓縮用模型

# ── Embedding ──

# EMBEDDING_MODEL=openai/text-embedding-3-small  # Embedding 模型 ID（使用同 provider API 設定）
# EMBEDDING_DIMENSIONS=1536                      # 向量維度（需與模型輸出一致）

# ── Debounce — 控制何時觸發 AI 回覆 ──

# DEBOUNCE_SILENCE_MS=15000      # 靜默觸發：最後一則訊息後 N ms 無新訊息即觸發
# DEBOUNCE_URGENT_MS=2000        # @mention 急迫模式：被 mention 時改用較短等待時間
# DEBOUNCE_OVERFLOW_CHARS=3000   # 溢出觸發：buffer 累積字元超過此值即立刻觸發

# ── Frequency — 回應頻率控制 ──

# FREQUENCY_ENABLED=true                # 頻率控制器總開關
# FREQUENCY_LONG_HALFLIFE_HOURS=120     # 長期 EMA 半衰期（小時），預設 5 天
# FREQUENCY_SHORT_HALFLIFE_HOURS=4      # 短期 EMA 半衰期（小時），防止連發
# FREQUENCY_ACTIVE_WINDOW_DAYS=7        # 計算活躍人數的時間窗口（天）

# ── Scheduler — 排程器輪詢設定 ──

# SCHEDULER_POLL_INTERVAL_MS=2000  # 排程器輪詢間隔（ms）

# ── Context — 控制送給 AI 的上下文內容 ──

# CONTEXT_MAX_TOKENS=4000              # system prompt + 摘要的 token 預算上限
# CONTEXT_SEMANTIC_TOP_K=5             # 語義搜尋回傳的最大筆數
# CONTEXT_SEMANTIC_THRESHOLD=0.7       # 語義搜尋距離閾值（0~2，越小越嚴格）
# CONTEXT_RECENT_MESSAGE_COUNT=20      # 從 DB 取近期訊息的筆數
# CONTEXT_TOKEN_ESTIMATE_RATIO=3       # token 估算比率：每 N 字元約為 1 token
# CHUNK_TOKEN_LIMIT=500                # Chunk 分割的 token 上限

# ── Observer — 背景記憶壓縮 ──

# OBSERVER_MESSAGE_THRESHOLD=50   # 累積多少則訊息才觸發新一輪壓縮
# OBSERVER_USER_MESSAGE_LIMIT=50  # 壓縮用戶摘要時取最近 N 則該用戶訊息

# ── Delivery — 訊息投遞與平台限制 ──

# DELIVERY_DISCORD_MAX_LENGTH=2000          # Discord 單則訊息字元上限
# DELIVERY_LINE_MAX_LENGTH=5000             # LINE 單則訊息字元上限
# DELIVERY_DM_REPLY_TEXT=暫不支援私訊功能    # 私訊時的自動回覆文字
# DELIVERY_REPLY_TOKEN_FRESHNESS_MS=50000   # LINE replyToken 有效時間（ms）

# ── Bot 身份 ──

# BOT_USER_ID=bot    # Bot 的 userId（用於 DB）
# BOT_USER_NAME=Bot  # Bot 的顯示名稱（用於 DB）

# ── Logging — 日誌輪替 ──

# LOG_DIR=./logs               # 日誌檔案輸出目錄
# LOG_ROTATION_FREQUENCY=daily # 輪替頻率
# LOG_MAX_SIZE=100M            # 單一日誌檔案大小上限
# LOG_MAX_RETENTION=30d        # 日誌最大保留時間

# ── Shutdown — Agent 關閉行為 ──

# SHUTDOWN_TIMEOUT_MS=30000       # 等待 AI pipeline 完成的最大時間（ms）
# SHUTDOWN_POLL_INTERVAL_MS=100   # 輪詢 isProcessing 狀態的間隔（ms）

# ── Litestream 備份（生產環境用，開發環境不需要設定）──

# LITESTREAM_BUCKET=your-s3-bucket-name
# LITESTREAM_ENDPOINT=https://s3.amazonaws.com  # 或 Cloudflare R2 endpoint
# LITESTREAM_ACCESS_KEY_ID=your-access-key-id
# LITESTREAM_SECRET_ACCESS_KEY=your-secret-access-key
